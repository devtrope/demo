{% extends 'base.html.twig' %}

{% block title %}Modifier un ticket{% endblock %}

{% block content %}
    <div class="add-ticket">
        <h1>Modifier un ticket</h1>
        <form action="/ticket/update" method="POST">
            <input type="hidden" name="id" value="{{ ticket.id }}" />
            <div class="row">
                <div class="col-lg-12">
                    <label for="title" class="form-label">Titre</label>
                    <input type="text" class="form-control" name="title" id="title" value="{{ ticket.title }}">
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" name="description" id="description">{{ ticket.description }}</textarea>
                </div>
                <div class="col-lg-12 mt-3">
                    <button class="btn btn-primary">Modifier le ticket</button>
                </div>
            </div>
        </form>
    </div>
{% endblock %}