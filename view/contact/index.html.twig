{% extends 'base.html.twig' %}
{% block title %}Nous contacter{% endblock %}
{% block content %}

<div class="min-h-[60vh] flex items-center justify-center">
    <div class="w-full max-w-sm">
        <div class="mb-8 text-center">
            <p class="font-mono text-accent text-sm font-medium mb-3">{{ config('app.name') }}</p>
            <h1 class="text-2xl font-medium text-ink-primary">Nous contacter</h1>
            <p class="text-sm text-ink-secondary mt-1.5">Si vous avez la moindre question, remplissez le formulaire ci-dessous pour nous contacter.</p>
        </div>

        <div class="bg-surface-raised border border-surface-border rounded-xl p-6">
            <form action="/contact" method="POST" class="space-y-4">
                {{ csrf() }}
                
                <div>
                    <label for="mail" class="block text-sm text-ink-secondary mb-1.5">Adresse mail</label>
                    <input type="text" name="mail" id="mail" autocomplete="mail"
                        class="w-full bg-surface border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors"
                        placeholder="nom.prenom@mail.fr" value="{{ old.mail ?? '' }}">
                </div>

                <div>
                    <label for="name" class="block text-sm text-ink-secondary mb-1.5">Nom</label>
                    {% set name = '' %}
                    {% if auth is defined %}
                        {% set name = auth.name %}
                    {% endif %}
                    <input type="text" name="name" id="name" autocomplete="name"
                        class="w-full bg-surface border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors"
                        placeholder="Votre nom" value="{{ old.name ?? name }}">
                </div>

                <div>
                    <label for="first_name" class="block text-sm text-ink-secondary mb-1.5">Prénom</label>
                    {% set firstName = '' %}
                    {% if auth is defined %}
                        {% set firstName = auth.firstName %}
                    {% endif %}
                    <input type="text" name="first_name" id="first_name" autocomplete="first_name"
                        class="w-full bg-surface border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors"
                        placeholder="Votre prénom" value="{{ old.first_name ?? firstName }}">
                </div>

                <div>
                    <label for="message" class="block text-sm text-ink-secondary mb-1.5">Message</label>
                    <textarea name="message" id="message" rows="10"
                        class="w-full bg-surface-raised border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors resize-none"
                        placeholder="Votre message...">{{ old.message ?? '' }}</textarea>
                </div>

                <div class="pt-1">
                    <button type="submit" class="w-full px-5 py-2.5 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-lg transition-colors">
                        Envoyer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}