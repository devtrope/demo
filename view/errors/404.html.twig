{% extends 'base.html.twig' %}
{% block title %}404{% endblock %}
{% block content %}

<div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
        <p class="font-mono text-6xl font-medium text-surface-border mb-6">404</p>
        <h1 class="text-xl font-medium text-ink-primary mb-2">Page introuvable</h1>
        <p class="text-sm text-ink-secondary mb-8">La page que vous cherchez n'existe pas ou a été déplacée.</p>
        <a href="/" class="inline-flex items-center gap-2 text-sm text-accent hover:text-accent-hover transition-colors">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Retour à l'accueil
        </a>
    </div>
</div>

{% endblock %}