<!DOCTYPE html>
<html lang="{{ config('app.locale') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ config('app.name') }} — {% block title %}{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['DM Sans', 'sans-serif'],
                        mono: ['DM Mono', 'monospace'],
                    },
                    colors: {
                        surface: {
                            DEFAULT: '#0f0f11',
                            raised: '#18181c',
                            border: '#2a2a30',
                            hover: '#222228',
                        },
                        accent: {
                            DEFAULT: '#7c6af7',
                            hover: '#9181f9',
                            muted: '#2d2845',
                            danger: '#e05d5d',
                        },
                        ink: {
                            primary: '#f0effe',
                            secondary: '#9d9ab0',
                            muted: '#5a5870',
                        },
                        status: {
                            success: '#34d399',
                            danger: '#f87171',
                            warning: '#fbbf24',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0f0f11; color: #f0effe; }
        * { border-color: #2a2a30; }
        ::selection { background: #2d2845; }
        ::-webkit-scrollbar { width: 6px; } 
        ::-webkit-scrollbar-track { background: #0f0f11; }
        ::-webkit-scrollbar-thumb { background: #2a2a30; border-radius: 3px; }
    </style>
    <link rel="stylesheet" href="{{ asset('style.css') }}">
</head>
<body class="font-sans antialiased min-h-screen">

    <nav class="border-b border-surface-border bg-surface-raised sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
            <a href="/" class="font-mono text-sm font-medium text-accent tracking-tight">
                <img src="{{ asset('images/logo.png') }}" class="h-8"/>
            </a>
            <div class="flex items-center gap-6">
                <a href="/" class="text-sm text-ink-secondary hover:text-ink-primary transition-colors">Accueil</a>
                <a href="/contact" class="text-sm text-ink-secondary hover:text-ink-primary transition-colors">Contact</a>
                {% if auth is defined %}
                    <span class="text-sm text-ink-muted">|</span>
                    <span class="text-sm text-ink-primary font-medium">{{ auth.firstName ~ " " ~ auth.name }}</span>
                    <form method="POST" action="/logout" class="inline">
                        {{ csrf() }}
                        <button type="submit" class="text-sm text-ink-secondary hover:text-status-danger transition-colors">
                            Déconnexion
                        </button>
                    </form>
                {% else %}
                    <a href="/login" class="text-sm px-3 py-1.5 rounded-md border border-surface-border hover:border-accent hover:text-accent transition-all">
                        Connexion
                    </a>
                {% endif %}
            </div>
        </div>
    </nav>

    {% if success is defined %}
        <div class="max-w-5xl mx-auto px-6 pt-4">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-status-success/10 border border-status-success/20 text-status-success text-sm">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 4L6 11L3 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {{ success }}
            </div>
        </div>
    {% endif %}

    {% if error is defined %}
        <div class="max-w-5xl mx-auto px-6 pt-4">
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-status-danger/10 border border-status-danger/20 text-status-danger text-sm">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                {{ error }}
            </div>
        </div>
    {% endif %}

    <main class="max-w-5xl mx-auto px-6 py-8">
        {% block content %}{% endblock %}
    </main>

</body>
</html>