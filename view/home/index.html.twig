{% extends 'base.html.twig' %}
{% block title %}Mes tickets{% endblock %}
{% block content %}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-medium text-ink-primary">Tickets</h1>
        <p class="text-sm text-ink-secondary mt-0.5">{{ tickets|length }} ticket{{ tickets|length > 1 ? 's' : '' }} au total</p>
    </div>
    {% if auth is defined %}
        <a href="/ticket/add" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-accent hover:bg-accent-hover text-white text-sm font-medium transition-colors">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Nouveau ticket
        </a>
    {% endif %}
</div>

{% if tickets|length == 0 %}
    <div class="text-center py-20 text-ink-muted">
        <p class="text-sm">Aucun ticket pour le moment.</p>
    </div>
{% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for ticket in tickets %}
            <div class="group bg-surface-raised border border-surface-border rounded-xl p-5 hover:border-accent/40 transition-all flex flex-col">
                {% if ticket.picture is not null %}
                    <img src="{{ image(ticket.picture) }}" class="w-full aspect-[16/9] object-cover rounded-lg mb-4" />
                {% endif %}

                <a href="/ticket/index/{{ ticket.id }}" class="block flex-1">
                    <h2 class="text-base font-medium text-ink-primary group-hover:text-accent transition-colors mb-2">
                        {{ ticket.title|truncate(50) }}
                    </h2>
                    <p class="text-sm text-ink-secondary leading-relaxed">
                        {{ ticket.description|truncate(100) }}
                    </p>
                </a>

                <div class="mt-3">
                    <span class="text-xs text-ink-muted font-mono">#{{ ticket.id|str_pad(8, '0') }}</span>
                </div>

                <div class="mt-4 pt-4 border-t border-surface-border space-y-1.5">
                    <div class="flex items-center gap-2 text-xs text-ink-muted">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="4" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M1.5 10.5c0-2.485 2.015-4.5 4.5-4.5s4.5 2.015 4.5 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                        <span>Par <span class="text-ink-secondary">{{ ticket.createdBy.firstName ~ " " ~ ticket.createdBy.name }}</span></span>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-ink-muted">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M10 6H6m0 0V2m0 4L2 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>Pour <span class="text-ink-secondary">{{ ticket.attributedTo.firstName ~ " " ~ ticket.attributedTo.name }}</span></span>
                    </div>
                </div>

                <div class="mt-3 flex items-center justify-between">
                    <span class="text-xs text-ink-muted font-mono">{{ ticket.createdAt|date('d/m/Y') }}</span>
                    <a href="/ticket/update/{{ ticket.id }}" class="text-xs text-ink-muted hover:text-accent transition-colors">
                        Modifier →
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}