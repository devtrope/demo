{% extends 'base.html.twig' %}

{% block title %}Ajouter un ticket{% endblock %}

{% block content %}
    <div class="add-ticket">
        {% if error is defined %}
            <div class="alert alert-danger">
                {{ error }}
            </div>
        {% endif %}
        <h1>Ajouter un ticket</h1>
        <form action="/ticket/add" method="POST" enctype="multipart/form-data">
            <div class="row">
                <div class="col-lg-6">
                    <label for="title" class="form-label">Titre</label>
                    <input type="text" class="form-control" name="title" id="title" value="{{ old.title }}">
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" name="description" id="description">{{ old.description }}</textarea>
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="picture" class="form-label">Image</label>
                    <input type="file" class="form-control" name="picture" id="picture">
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="attributed" class="form-label">Attribuer à</label>
                    <select class="form-select" name="attributed" id="attributed">
                        {% for user in users %}
                            <option value="{{ user.id }}" {% if old.attributed is defined and old.attributed == user.id %}selected="selected"{% endif %}>{{ user.firstName ~  " " ~  user.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-12 mt-3">
                    <button class="btn btn-primary">Ajouter le ticket</button>
                </div>
            </div>
        </form>
    </div>
{% endblock %}