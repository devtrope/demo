{% extends 'base.html.twig' %}
{% block title %}Ajouter un ticket{% endblock %}
{% block content %}

<div class="max-w-2xl">
    <div class="mb-8">
        <a href="/" class="text-sm text-ink-muted hover:text-ink-secondary transition-colors inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Retour
        </a>
        <h1 class="text-2xl font-medium text-ink-primary mt-3">Nouveau ticket</h1>
    </div>

    <form action="/ticket/add" method="POST" enctype="multipart/form-data" class="space-y-5">

        <div>
            <label for="title" class="block text-sm text-ink-secondary mb-1.5">Titre</label>
            <input type="text" name="title" id="title" value="{{ old.title ?? '' }}"
                class="w-full bg-surface-raised border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors"
                placeholder="Titre du ticket">
        </div>

        <div>
            <label for="description" class="block text-sm text-ink-secondary mb-1.5">Description</label>
            <textarea name="description" id="description" rows="10"
                class="w-full bg-surface-raised border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary placeholder-ink-muted focus:outline-none focus:border-accent transition-colors resize-none"
                placeholder="Décrivez le ticket...">{{ old.description ?? '' }}</textarea>
        </div>

        <div>
            <label for="picture" class="block text-sm text-ink-secondary mb-1.5">Image <span class="text-ink-muted">(optionnel)</span></label>
            <input type="file" name="picture" id="picture"
                class="w-full bg-surface-raised border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-muted file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-accent-muted file:text-accent file:text-xs file:font-medium cursor-pointer focus:outline-none focus:border-accent transition-colors">
        </div>

        <div>
            <label for="attributed" class="block text-sm text-ink-secondary mb-1.5">Attribuer à</label>
            <select name="attributed" id="attributed"
                class="w-full bg-surface-raised border border-surface-border rounded-lg px-3.5 py-2.5 text-sm text-ink-primary focus:outline-none focus:border-accent transition-colors appearance-none">
                {% for user in users %}
                    <option value="{{ user.id }}" {% if old.attributed is defined and old.attributed == user.id %}selected{% endif %}>
                        {{ user.firstName ~ " " ~ user.name }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="pt-2">
            <button type="submit" class="px-5 py-2.5 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-lg transition-colors">
                Créer le ticket
            </button>
        </div>
    </form>
</div>

{% endblock %}