{% extends 'base.html.twig' %}
{% block title %}{{ ticket.title }}{% endblock %}
{% block content %}

<div class="max-w-2xl">
    <div class="mb-8">
        <a href="/" class="text-sm text-ink-muted hover:text-ink-secondary transition-colors inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Retour
        </a>
    </div>

    <div class="bg-surface-raised border border-surface-border rounded-xl p-6">
        {% if ticket.picture is not null %}
            <img src="{{ image(ticket.picture) }}" class="w-full aspect-[16/9] object-cover rounded-lg mb-4" />
        {% endif %}
        <div class="flex items-start justify-between gap-4 mb-6">
            <h1 class="text-xl font-medium text-ink-primary leading-snug">{{ ticket.title }}</h1>
            {% if auth is defined %}
                <a href="/ticket/update/{{ ticket.id }}" class="shrink-0 text-xs px-3 py-1.5 rounded-md border border-surface-border hover:border-accent hover:text-accent transition-all text-ink-secondary">
                    Modifier
                </a>
            {% endif %}
        </div>

        <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-line">{{ ticket.description }}</p>

        <div class="mt-6 pt-5 border-t border-surface-border grid grid-cols-2 gap-4">
            <div>
                <p class="text-xs text-ink-muted mb-1">Créé par</p>
                <p class="text-sm text-ink-primary">{{ ticket.createdBy.firstName ~ " " ~ ticket.createdBy.name }}</p>
            </div>
            <div>
                <p class="text-xs text-ink-muted mb-1">Attribué à</p>
                <p class="text-sm text-ink-primary">{{ ticket.attributedTo.firstName ~ " " ~ ticket.attributedTo.name }}</p>
            </div>
            <div>
                <p class="text-xs text-ink-muted mb-1">Date de création</p>
                <p class="text-sm font-mono text-ink-secondary">{{ ticket.createdAt|date('d/m/Y à H:i') }}</p>
            </div>
        </div>
    </div>
</div>

{% endblock %}