{% extends 'base.html.twig' %}

{% block title %}Modifier un ticket{% endblock %}

{% block content %}
    <div class="add-ticket">
        {% if error is defined %}
            <div class="alert alert-danger">
                {{ error }}
            </div>
        {% endif %}
        <h1>Modifier un ticket</h1>
        <form action="/ticket/update" method="POST">
            <input type="hidden" name="id" value="{{ ticket.id }}" />
            <div class="row">
                <div class="col-lg-6">
                    <label for="title" class="form-label">Titre</label>
                    <input type="text" class="form-control" name="title" id="title" value="{{ old.title ?? ticket.title }}">
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" name="description" id="description">{{ old.description ?? ticket.description }}</textarea>
                </div>
                <div class="col-lg-12 mt-3">
                    <label for="attributed" class="form-label">Attribuer à</label>
                    <select class="form-select" name="attributed" id="attributed">
                        {% for user in users %}
                            <option value="{{ user.id }}" {% if user.id == ticket.attributedTo.id %}selected="selected"{% endif %}>{{ user.firstName ~  " " ~  user.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-12 mt-3">
                    <button class="btn btn-primary">Modifier le ticket</button>
                </div>
            </div>
        </form>
    </div>
{% endblock %}